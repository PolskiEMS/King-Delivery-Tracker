generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  DRIVER
}

enum DispatcherStatus {
  AVAILABLE
  ACTIVE
  INACTIVE
  BUSY
  AWAY
  OFFLINE
}

enum OrderStatus {
  NEW
  ASSIGNED
  IN_DELIVERY
  DELIVERED
  PROBLEM
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  PROBLEM
  CANCELLED
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  password      String   @default("")
  firstName     String
  lastName      String
  role          UserRole
  dispatcherStatus DispatcherStatus @default(OFFLINE)
  createdAt     DateTime @default(now())
}

model Driver {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  routes    Route[]
}

model Vehicle {
  id           String   @id @default(cuid())
  registration String   @unique
  brand        String?
  model        String?
  pallets      Int?
  createdAt    DateTime @default(now())

  routes       Route[]
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  customerName String
  address      String
  city         String
  postalCode   String?
  country      String      @default("UK")
  goodsName    String
  quantity     Float
  unit         String      @default("szt.")
  pallets      Int?
  weightKg     Float?
  notes        String?
  status       OrderStatus @default(NEW)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  delivery     Delivery?

  @@index([createdAt])
}

model Route {
  id          String      @id @default(cuid())
  routeNumber String      @unique
  name        String
  plannedDate DateTime?
  status      RouteStatus @default(PLANNED)
  notes       String?
  driverId    String?
  vehicleId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  driver      Driver?     @relation(fields: [driverId], references: [id])
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id])
  deliveries  Delivery[]

  @@index([createdAt])
  @@index([driverId])
  @@index([vehicleId])
}

model Delivery {
  id          String         @id @default(cuid())
  deliveryNumber String     @unique
  orderId     String         @unique
  routeId     String?
  sequence    Int?
  status      DeliveryStatus @default(PENDING)
  deliveredAt DateTime?
  problemNote String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  order       Order          @relation(fields: [orderId], references: [id])
  route       Route?         @relation(fields: [routeId], references: [id])

  @@index([createdAt])
  @@index([routeId])
}